Proceso Compra_simple
	Definir Precio, Cantidad, Total Como Entero;
	
	Escribir "Ingrese el precio del producto";
	Leer Precio;
	
	Escribir "Dime la cantidad";
	Leer Cantidad;
	
	Total<-Precio*Cantidad;
	
	Escribir "Total a pagar ", Total;
	
FinProceso
